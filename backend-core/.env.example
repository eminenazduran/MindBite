# Sunucu Ayarları
PORT=5000
NODE_ENV=development

# MongoDB Bağlantı Adresi
# Örnek: mongodb+srv://<kullanici>:<sifre>@cluster0.abcde.mongodb.net/gidaDB?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/akilli_gida_platformu

# Google Gemini API Anahtarı (Google AI Studio'dan alın: https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# JSON Web Token Secret (güçlü, rastgele bir string kullanın)
JWT_SECRET=your_super_secret_jwt_key_here
