# ============================================================
# MindBite - Root .gitignore
# ============================================================

# ── Dependency directories ──────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment / Secrets ────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ── Build outputs ────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── TypeScript cache ─────────────────────────────────────────
*.tsbuildinfo

# ── Misc ─────────────────────────────────────────────────────
.cache/
.temp/
*.local
